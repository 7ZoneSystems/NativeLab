<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ph_window_bg">

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/ph_window_bg"
        android:padding="12dp"
        android:clipToPadding="false" />

    <!-- Download progress bar (green, shown during model download) -->
    <LinearLayout
        android:id="@+id/download_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp"
        android:background="@color/ph_surface"
        android:visibility="gone">

        <TextView
            android:id="@+id/download_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Downloading model…"
            android:textColor="@color/ph_ok"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/download_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/ph_progress_drawable" />
    </LinearLayout>

    <!-- Generating / Loading banner -->
    <LinearLayout
        android:id="@+id/generating_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@color/ph_surface"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/gen_progress"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/ph_accent" />

        <TextView
            android:id="@+id/generating_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Generating…"
            android:textColor="@color/ph_accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="8dp" />

        <ImageButton
            android:id="@+id/btn_stop"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Stop"
            android:tint="@color/ph_err"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- RAG processing bar -->
    <LinearLayout
        android:id="@+id/rag_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp"
        android:background="@color/ph_surface"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_rag_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Processing document…"
            android:textColor="@color/ph_accent"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progress_rag"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/ph_progress_drawable" />
    </LinearLayout>

    <!-- Attachment preview chip -->
    <LinearLayout
        android:id="@+id/attachment_chip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@color/ph_chat_input_bg"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_attachment_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="@color/ph_accent"
            android:textSize="12sp"
            android:drawablePadding="6dp"
            android:ellipsize="middle"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/btn_clear_attachment"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Remove"
            android:tint="@color/ph_err"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Bottom input bar: [Model ▾] [Input] [Send] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/ph_chat_input_bg"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btn_attach"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_add"
            android:contentDescription="Attach"
            android:tint="@color/ph_accent"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/btn_model_picker"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="4dp"
            android:text="Model ▾"
            android:textColor="@color/ph_accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/ph_spinner_bg"
            android:maxLines="1"
            android:ellipsize="end"
            android:minWidth="70dp" />

        <EditText
            android:id="@+id/prompt_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:minHeight="44dp"
            android:maxHeight="120dp"
            android:hint="Message PhonoLab…"
            android:inputType="textMultiLine|textCapSentences"
            android:background="@drawable/ph_input_bg"
            android:padding="12dp"
            android:textColor="@color/ph_txt"
            android:textColorHint="@color/ph_txt3"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:importantForAutofill="no" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/ph_btn_primary"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Send"
            android:tint="#ffffff"
            android:scaleType="centerInside" />
    </LinearLayout>
</LinearLayout>
