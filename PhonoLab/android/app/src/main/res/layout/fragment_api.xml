<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ph_window_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Endpoint"
            android:textColor="@color/ph_txt"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expose PhonoLab as an API server on your network. Other NativeLab nodes can send requests here."
            android:textColor="@color/ph_txt2"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ph_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ph_bdr"
            app:strokeWidth="1dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/api_status_icon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:text="●"
                        android:textSize="12sp"
                        android:textColor="@color/ph_txt3"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/api_status_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Server stopped"
                        android:textColor="@color/ph_txt2"
                        android:textSize="13sp"
                        android:paddingStart="8dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ph_divider"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <!-- Protocol selector -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Protocol:"
                        android:textColor="@color/ph_txt2"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/protocol_spinner"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/ph_spinner_bg" />
                </LinearLayout>

                <!-- Port -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Port:"
                        android:textColor="@color/ph_txt2"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/port_input"
                        android:layout_width="80dp"
                        android:layout_height="36dp"
                        android:text="8787"
                        android:textColor="@color/ph_txt"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:inputType="number"
                        android:background="@drawable/ph_input_bg"
                        android:padding="6dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Endpoints Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENDPOINT URLS"
            android:textColor="@color/ph_txt3"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ph_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ph_bdr"
            app:strokeWidth="1dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Local URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Local"
                    android:textColor="@color/ph_txt3"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/local_url"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="http://127.0.0.1:8787/v1"
                        android:textColor="@color/ph_accent"
                        android:textSize="12sp"
                        android:textIsSelectable="true" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_local"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Copy"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- LAN URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAN / WiFi"
                    android:textColor="@color/ph_txt3"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/lan_url"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="http://0.0.0.0:8787/v1"
                        android:textColor="@color/ph_accent"
                        android:textSize="12sp"
                        android:textIsSelectable="true" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_lan"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Copy"
                        android:textSize="11sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ph_divider"
                    android:layout_marginBottom="10dp" />

                <!-- API Keys -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API KEYS"
                    android:textColor="@color/ph_txt3"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="Local"
                        android:textColor="@color/ph_txt2"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/local_key"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="nl-xxxx..."
                        android:textColor="@color/ph_txt3"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:singleLine="true"
                        android:ellipsize="middle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_local_key"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="Copy"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="LAN"
                        android:textColor="@color/ph_txt2"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/lan_key"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="nl-yyyy..."
                        android:textColor="@color/ph_txt3"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:singleLine="true"
                        android:ellipsize="middle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_lan_key"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="Copy"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Start/Stop buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_server"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="Start Server"
                android:textSize="13sp"
                app:backgroundTint="@color/ph_accent"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop_server"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Stop"
                android:textSize="13sp"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Endpoints Reference Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AVAILABLE ENDPOINTS"
            android:textColor="@color/ph_txt3"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ph_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ph_bdr"
            app:strokeWidth="1dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GET  /health\nGET  /runtime\nGET  /v1/models\nGET  /capabilities\nPOST /v1/chat/completions\nPOST /v1/completions\nPOST /v1/messages"
                    android:textColor="@color/ph_txt2"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Request Log Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REQUEST LOG"
            android:textColor="@color/ph_txt3"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ph_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ph_bdr"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/request_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No requests yet."
                android:textColor="@color/ph_txt3"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:padding="14dp"
                android:lineSpacingMultiplier="1.4" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
