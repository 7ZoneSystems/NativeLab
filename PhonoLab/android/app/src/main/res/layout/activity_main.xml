<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/ph_window_bg">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/ph_toolbar_bg"
            app:navigationIcon="@drawable/ic_sidebar"
            app:titleTextColor="@color/ph_txt"
            app:subtitleTextColor="@color/ph_txt2" />

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Sidebar drawer -->
    <ScrollView
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/ph_drawer_bg"
        android:clickable="true"
        android:focusable="true"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <include layout="@layout/ph_nav_header" />

            <!-- ── MODELS button ── -->
            <LinearLayout
                android:id="@+id/nav_models"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/ph_sidebar_item_bg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_folder"
                    android:contentDescription="Models"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Models"
                    android:textColor="@color/ph_txt"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- ── DOWNLOADS button ── -->
            <LinearLayout
                android:id="@+id/nav_downloads"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/ph_sidebar_item_bg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_download"
                    android:contentDescription="Downloads"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Downloads"
                    android:textColor="@color/ph_txt"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- ── CHANGE THEME button ── -->
            <LinearLayout
                android:id="@+id/nav_theme_toggle"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/ph_sidebar_item_bg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_palette"
                    android:contentDescription="Change Theme"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change Theme"
                    android:textColor="@color/ph_txt"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Divider before New Chat -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ph_divider"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp" />

            <!-- ── NEW CHAT button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new_chat"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:text="＋  New Chat"
                android:textColor="#ffffff"
                android:textSize="14sp"
                app:backgroundTint="@color/ph_accent"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_plus"
                app:iconGravity="textStart"
                app:iconTint="#ffffff" />

            <!-- Divider before search -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ph_divider"
                android:layout_marginTop="6dp" />

            <!-- Search -->
            <EditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/ph_input_bg"
                android:hint="Search conversations…"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/ph_txt"
                android:textColorHint="@color/ph_txt3"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ph_divider" />

            <!-- Session history list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>
</androidx.drawerlayout.widget.DrawerLayout>
