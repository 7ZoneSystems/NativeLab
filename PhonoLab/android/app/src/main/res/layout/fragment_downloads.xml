<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ph_window_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Downloads"
            android:textColor="@color/ph_txt"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Download GGUF models and llama.cpp runtime."
            android:textColor="@color/ph_txt2"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp" />

        <!-- Runtime Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LLAMA.CPP RUNTIME"
            android:textColor="@color/ph_txt3"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ph_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ph_bdr"
            app:strokeWidth="1dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/runtime_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Checking runtime…"
                    android:textColor="@color/ph_txt2"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pull_runtime"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Pull llama.cpp Source"
                    android:textSize="12sp"
                    app:backgroundTint="@color/ph_accent"
                    app:cornerRadius="6dp" />

                <ProgressBar
                    android:id="@+id/runtime_progress"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progressDrawable="@drawable/ph_progress_drawable"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Model Catalog Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MODEL CATALOG"
            android:textColor="@color/ph_txt3"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ph_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ph_bdr"
            app:strokeWidth="1dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_catalog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:padding="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Active Downloads Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVE DOWNLOADS"
            android:textColor="@color/ph_txt3"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ph_card_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ph_bdr"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/downloads_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No active downloads."
                    android:textColor="@color/ph_txt3"
                    android:textSize="12sp"
                    android:gravity="center" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_downloads"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
