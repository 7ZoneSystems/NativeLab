<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══ Button Styles ═══ -->
    <style name="PhonoLab.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/ph_accent</item>
        <item name="android:textColor">#ffffff</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="PhonoLab.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/ph_bdr2</item>
        <item name="android:textColor">@color/ph_txt</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- ═══ Card Styles ═══ -->
    <style name="PhonoLab.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/ph_card_bg</item>
        <item name="strokeColor">@color/ph_bdr</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- ═══ Text Styles ═══ -->
    <style name="PhonoLab.Text.Title" parent="android:Widget.TextView">
        <item name="android:textColor">@color/ph_txt</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PhonoLab.Text.Section" parent="android:Widget.TextView">
        <item name="android:textColor">@color/ph_txt3</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="PhonoLab.Text.Caption" parent="android:Widget.TextView">
        <item name="android:textColor">@color/ph_txt2</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
